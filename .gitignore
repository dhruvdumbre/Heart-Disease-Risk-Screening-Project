# ===== ML model artifacts =====
# Regenerate these locally with 03_train_evaluate.py -- don't commit them.
# Pickled models are tied to the exact scikit-learn version that created
# them, so committing one and pulling it on another machine/env is a
# common source of "AttributeError" version-mismatch bugs.
*.joblib
*.pkl
*.pickle
*.h5

# ===== Generated data & outputs =====
# heart_data.csv / diabetes_data.csv are generated by 01_generate_data.py
# with a fixed random seed, so they're reproducible -- no need to version
# them. Comment out the lines below if you'd rather track your data.
*.csv
outputs/
plots/
model_comparison.csv

# ===== Streamlit =====
.streamlit/secrets.toml

# ===== Environment variables / secrets =====
.env
*.env.local

# ===== IDE =====
.vscode/
.idea/
*.swp

